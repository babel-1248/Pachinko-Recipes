prefix_rule(
    pattern = ["python3", "get_new_pdfs.py"],
    decision = "allow",
    justification = "Allow scanning PDF_FOLDER for new files.",
)

prefix_rule(
    pattern = ["python3", "convert_pdf.py"],
    decision = "allow",
    justification = "Allow converting a PDF to markdown.",
)

prefix_rule(
    pattern = ["python3", "mark_converted.py"],
    decision = "allow",
    justification = "Allow updating the converted_pdfs.json state file.",
)

prefix_rule(
    pattern = ["python3", "-c", "import pymupdf4llm"],
    decision = "allow",
    justification = "Allow checking whether pymupdf4llm is installed.",
)

prefix_rule(
    pattern = ["pip", "install", "pymupdf4llm"],
    decision = "allow",
    justification = "Allow installing pymupdf4llm if it is missing.",
)

prefix_rule(
    pattern = ["python3", "-c", "import anthropic"],
    decision = "allow",
    justification = "Allow checking whether the anthropic Python package is installed.",
)

prefix_rule(
    pattern = ["pip", "install", "anthropic"],
    decision = "allow",
    justification = "Allow installing the anthropic Python package if it is missing.",
)
